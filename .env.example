# Memoreei Configuration
# Copy to .env and fill in values

# Embedding provider: "fastembed" (default, no API key needed) or "openai"
EMBEDDING_PROVIDER=fastembed

# Required only if EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# Discord bot token for syncing Discord messages
# DISCORD_BOT_TOKEN=

# Discord channel ID to sync
# DISCORD_CHANNEL_ID=your_channel_id_here

# Path to the SQLite database file
MEMOREEI_DB_PATH=./memoreei.db
